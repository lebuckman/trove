# Supabase project credentials (Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Used by `npm run types` to regenerate src/lib/supabase/types.ts.
SUPABASE_PROJECT_ID=<project-ref>

# Public site origin — sets metadataBase for absolute OG/icon URLs.
# Defaults to http://localhost:3000 when unset.
NEXT_PUBLIC_SITE_URL=https://<your-domain>
